name: emotion-lstm-ci

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      data_dir: {type: str, default: "namadataset_preprocessing"}
      max_words: {type: int, default: 20000}
      max_len: {type: int, default: 50}
      embedding_dim: {type: int, default: 128}
      lstm_units: {type: int, default: 64}
      dropout_rate: {type: float, default: 0.2}
      batch_size: {type: int, default: 64}
      epochs: {type: int, default: 5}
    command: >
      python modelling.py
      --data_dir {data_dir}
      --max_words {max_words}
      --max_len {max_len}
      --embedding_dim {embedding_dim}
      --lstm_units {lstm_units}
      --dropout_rate {dropout_rate}
      --batch_size {batch_size}
      --epochs {epochs}